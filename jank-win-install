#!/usr/bin/env bash
#
# Download and install jank and LLVM related MSYS2 CLANG64 binary
# release packages from the jank-win-release site.
#
# set -x

set -euo pipefail

LLVM_TAG="llvm-26-01-16-jank4"
JANK_TAG="jank-test-9"
BASE_URL="https://github.com/ikappaki/jank-win-release/releases/download"

INSTALL_LLVM=true
INSTALL_JANK=true
REMOVE_DIRS=true

if [[ "${MSYSTEM:-}" != "CLANG64" ]]; then
  echo "Error: This script must be run from an MSYS2 CLANG64 shell."
  exit 1
fi

# parse CLI flags
while [[ $# -gt 0 ]]; do
  case "$1" in
    --llvm-only)
      INSTALL_LLVM=true
      INSTALL_JANK=false
      shift
      ;;
    --jank-only)
      INSTALL_LLVM=false
      INSTALL_JANK=true
      shift
      ;;
    --keep-dirs)
      REMOVE_DIRS=false
      shift
      ;;
    --help|-h)
      echo "Usage: $0 [--llvm-only] [--jank-only] [--keep-dirs]"
      exit 0
      ;;
    *)
      echo "Unknown option: $1"
      exit 1
      ;;
  esac
done

msg() {
  echo -e "\n$*\n"
}

install_llvm() {
    local LLVM_BASE_URL="${BASE_URL}/${LLVM_TAG}"
    local ARCHIVE="${LLVM_TAG}.tar"
    local CHECKSUM="${ARCHIVE}.sha256"
    local DEST="$LLVM_TAG"

    echo "==> Installing ${LLVM_TAG} from ${LLVM_BASE_URL}"

    msg "==> Installing required tools"
    pacman -S --needed --noconfirm curl tar

    msg "==> Creating destination directory: $DEST"
    mkdir -p "$DEST"
    pushd "$DEST"
      curl -LO "${LLVM_BASE_URL}/${CHECKSUM}"

      # verify existing archive if present
      if [[ -f "$ARCHIVE" ]] && sha256sum -c "$CHECKSUM"; then
          msg "==> Using existing archive"
      else
          msg "==> Downloading archive: $ARCHIVE"
          rm -f "$ARCHIVE"
          curl -fL -O -C - "${LLVM_BASE_URL}/${ARCHIVE}"
          msg "==> Verifying checksum"
          sha256sum -c "$CHECKSUM"
      fi

      msg "==> Extracting archive"
      tar -xf "$ARCHIVE"

      msg "==> Installing packages"
      pacman -U --noconfirm ./*.pkg.tar.zst
    popd

    $REMOVE_DIRS && rm -rf "$DEST"

    msg "==> LLVM installation done!"
    clang --version
    echo
}

install_jank() {
    JANK_BASE_URL="${BASE_URL}/${JANK_TAG}"
    JANK_PKG="mingw-w64-clang-x86_64-jank-0.0.1-${JANK_TAG//-/_}-any.pkg.tar.zst"
    JANK_CHECKSUM="${JANK_PKG}.sha256"
    JANK_DEST="$JANK_TAG"

    echo "==> Installing jank-win from ${JANK_BASE_URL}"

    msg "==> Installing required tools"
    pacman -S --needed --noconfirm curl

    mkdir -p "$JANK_DEST"
    pushd "$JANK_DEST"
      curl -LO "${JANK_BASE_URL}/${JANK_CHECKSUM}"

      # verify existing archive if present
      if [[ -f "$JANK_PKG" ]] && sha256sum -c "$JANK_CHECKSUM"; then
          msg "==> Using existing archive"
      else
          msg "==> Downloading archive: $JANK_PKG"
          rm -f "$JANK_PKG"
          curl -fL -O -C - "${JANK_BASE_URL}/${JANK_PKG}"
          msg "==> Verifying checksum"
          sha256sum -c "$JANK_CHECKSUM"
      fi

      msg "==> Installing jank-win package"
      pacman -U --noconfirm "$JANK_PKG"
    popd

    $REMOVE_DIRS && rm -rf "$JANK_DEST"

    msg "==> jank-win installation done!"

    jank_path="$(command -v jank 2>/dev/null)";
    echo "jank executable:"
    echo "  MSYS2   path:  $jank_path"
    echo "  Windows path:  $(cygpath -w "$jank_path")"
}

# ----------------------
# Execute selected functions
# ----------------------
if [[ "$INSTALL_LLVM" == true ]]; then
    install_llvm
fi

if [[ "$INSTALL_JANK" == true ]]; then
    install_jank
fi
